{
    "name": "spip/spip-cli",
    "description": "Command Line for SPIP",
    "keywords": [
        "spip",
        "cli"
    ],
    "require": {
        "php": "^7.4 || ^8",
        "psr/container": "^1.1",
        "symfony/console": "^5.4",
        "symfony/finder": "^5.4",
        "symfony/process": "^5.4"
    },
    "require-dev": {
        "rector/rector": "^2.0",
        "spip-league/easy-coding-standard": "^1.1"
    },
    "repositories": {
        "spip": {
            "type": "composer",
            "url": "https://get.spip.net/composer"
        }
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Spip\\Cli\\": "src"
        }
    },
    "bin": [
        "bin/spip",
        "bin/spip_console_autocomplete"
    ],
    "config": {
        "platform": {
            "php": "7.4.33"
        }
    },
    "scripts": {
        "check-cs": "vendor/bin/ecs check --ansi",
        "fix-cs": "vendor/bin/ecs check --fix --ansi",
        "rector": "vendor/bin/rector process --ansi",
        "rector-dry-run": "vendor/bin/rector process --dry-run --ansi"
    }
}
